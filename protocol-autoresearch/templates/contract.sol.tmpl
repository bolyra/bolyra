 *      modify production contracts in contracts/.
 */
contract {{CONTRACT_NAME}} {
    // ---------------------------------------------------------------
    // Errors
    // ---------------------------------------------------------------
    error InvalidProof();
    error NullifierAlreadyUsed(uint256 nullifier);
    error StaleRoot(uint256 root);
    error Unauthorized(address caller);

    // ---------------------------------------------------------------
    // Events
    // ---------------------------------------------------------------
    event ProofVerified(
        uint256 indexed nullifierHash,
        uint256 indexed externalNullifier,
        uint256 root,
        address verifier
    );

    // ---------------------------------------------------------------
    // State
    // ---------------------------------------------------------------
    IVerifier public immutable verifier;
    mapping(uint256 => bool) public nullifierUsed;
    mapping(uint256 => bool) public validRoots;

    uint256 public constant ROOT_HISTORY_SIZE = 30;
    uint256[30] public rootHistory;
    uint256 public rootIndex;

    // ---------------------------------------------------------------
    // Constructor
    // ---------------------------------------------------------------
    constructor(address _verifier) {
        verifier = IVerifier(_verifier);
    }

    // ---------------------------------------------------------------
    // Root management
    // ---------------------------------------------------------------
    function _addRoot(uint256 root) internal {
        rootHistory[rootIndex % ROOT_HISTORY_SIZE] = root;
        rootIndex++;
        validRoots[root] = true;
    }

    function isValidRoot(uint256 root) public view returns (bool) {
        return validRoots[root];
    }

    // ---------------------------------------------------------------
    // Verification
    // ---------------------------------------------------------------
    function verify(
        uint256 merkleRoot,
        uint256 nullifierHash,
        uint256 externalNullifier,
        uint256[8] calldata proof
    ) external {
        if (!isValidRoot(merkleRoot)) revert StaleRoot(merkleRoot);
        if (nullifierUsed[nullifierHash]) revert NullifierAlreadyUsed(nullifierHash);

        bool valid = verifier.verifyProof(
            [proof[0], proof[1]],
            [[proof[2], proof[3]], [proof[4], proof[5]]],
            [proof[6], proof[7]],
            [merkleRoot, nullifierHash, externalNullifier]
        );
        if (!valid) revert InvalidProof();

        nullifierUsed[nullifierHash] = true;
        emit ProofVerified(nullifierHash, externalNullifier, merkleRoot, address(verifier));
    }

    // TODO: Add experiment-specific functions below
