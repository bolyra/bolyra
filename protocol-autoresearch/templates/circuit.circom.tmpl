pragma circom 2.1.6;

include "../../../circuits/src/lib/poseidon.circom";
include "../../../circuits/src/lib/binary_merkle_root.circom";

// {{DESCRIPTION}}
template {{TEMPLATE_NAME}}(TREE_DEPTH) {
    // ---------------------------------------------------------------
    // Public inputs
    // ---------------------------------------------------------------
    signal input merkleRoot;          // Current tree root
    signal input nullifierHash;       // Prevents double-spending
    signal input externalNullifier;   // Domain separation for nullifiers

    // ---------------------------------------------------------------
    // Private inputs
    // ---------------------------------------------------------------
    signal input identityCommitment;  // Poseidon(identitySecret)
    signal input identitySecret;      // Private key material
    signal input treeSiblings[TREE_DEPTH];
    signal input treePathIndices[TREE_DEPTH];

    // ---------------------------------------------------------------
    // Outputs
    // ---------------------------------------------------------------
    signal output root;               // Computed root for verification

    // ---------------------------------------------------------------
    // Step 1: Verify identity commitment
    // ---------------------------------------------------------------
    component commitmentHasher = Poseidon(1);
    commitmentHasher.inputs[0] <== identitySecret;
    commitmentHasher.out === identityCommitment;

    // ---------------------------------------------------------------
    // Step 2: Merkle inclusion proof
    // ---------------------------------------------------------------
    component merkleProof = BinaryMerkleRoot(TREE_DEPTH);
    merkleProof.leaf <== identityCommitment;
    for (var i = 0; i < TREE_DEPTH; i++) {
        merkleProof.siblings[i] <== treeSiblings[i];
        merkleProof.pathIndices[i] <== treePathIndices[i];
    }
    merkleProof.root === merkleRoot;

    // ---------------------------------------------------------------
    // Step 3: Nullifier computation (domain-separated)
    // ---------------------------------------------------------------
    component nullifierHasher = Poseidon(2);
    nullifierHasher.inputs[0] <== identitySecret;
    nullifierHasher.inputs[1] <== externalNullifier;
    nullifierHasher.out === nullifierHash;

    // ---------------------------------------------------------------
    // Output
    // ---------------------------------------------------------------
    root <== merkleProof.root;

    // TODO: Add experiment-specific constraints below
    // {{CUSTOM_CONSTRAINTS}}
}

// Default instantiation (depth 20 for ~1M identities)
component main {public [merkleRoot, nullifierHash, externalNullifier]} = {{TEMPLATE_NAME}}(20);
