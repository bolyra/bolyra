def create_bolyra_tool(
    wasm_path: str,
    zkey_path: str,
    verification_key_path: str,
    **kwargs: Any,
) -> BolyraAuthTool:
    """Create a configured Bolyra auth tool in 3 lines.

    Example:
        tool = create_bolyra_tool("./circuit.wasm", "./circuit.zkey", "./vkey.json")
        result = tool.run({"action": "authenticate", "scope": 0xFF})
    """
    config = BolyraConfig(
        wasm_path=wasm_path,
        zkey_path=zkey_path,
        verification_key_path=verification_key_path,
        **kwargs,
    )
    return BolyraAuthTool(config=config)
