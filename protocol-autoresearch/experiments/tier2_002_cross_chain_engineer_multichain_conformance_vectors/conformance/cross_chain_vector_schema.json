{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bolyra.dev/conformance/cross-chain-vector/v1",
  "title": "Bolyra Cross-Chain Conformance Test Vector",
  "description": "Schema for cross-chain identity proof verification test vectors in the Bolyra conformance suite.",
  "type": "object",
  "required": [
    "vectorId",
    "version",
    "category",
    "description",
    "sourceChainId",
    "targetChainId",
    "relayTimestamp",
    "rootAge",
    "maxRootAge",
    "proof",
    "publicInputs",
    "expectedResult",
    "failureReason"
  ],
  "properties": {
    "vectorId": {
      "type": "string",
      "pattern": "^cv_[0-9]{2}_[a-z_]+$",
      "description": "Unique identifier for this test vector, e.g. cv_01_unbound_chain_id"
    },
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for forward compatibility"
    },
    "category": {
      "type": "string",
      "enum": [
        "chain_id_binding",
        "root_staleness",
        "storage_proof",
        "batch_checkpoint",
        "nullifier_replay",
        "relay_timestamp"
      ],
      "description": "Category of the invariant being tested"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable description of what this vector tests"
    },
    "sourceChainId": {
      "type": "integer",
      "minimum": 1,
      "description": "EIP-155 chain ID where the proof was originally generated"
    },
    "targetChainId": {
      "type": "integer",
      "minimum": 1,
      "description": "EIP-155 chain ID where the proof is being verified"
    },
    "relayTimestamp": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Unix timestamp (seconds) when the root was relayed to the target chain. Null if intentionally absent."
    },
    "rootAge": {
      "type": "integer",
      "minimum": 0,
      "description": "Age of the Merkle root in seconds at time of verification"
    },
    "maxRootAge": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum acceptable root age in seconds (TTL threshold)"
    },
    "proof": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]+$",
      "description": "Hex-encoded proof bytes (Groth16 or Plonk)"
    },
    "publicInputs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]{1,64}$"
      },
      "minItems": 1,
      "description": "Array of hex-encoded field elements constituting the public inputs"
    },
    "expectedResult": {
      "type": "string",
      "enum": ["pass", "fail"],
      "description": "Whether a conformant verifier should accept or reject this vector"
    },
    "failureReason": {
      "type": ["string", "null"],
      "enum": [
        null,
        "CHAIN_ID_UNBOUND",
        "CHAIN_ID_MISMATCH",
        "ROOT_EXPIRED",
        "INVALID_BLOCK_HASH",
        "BLOCK_HASH_CHAIN_MISMATCH",
        "BATCH_INVALID_LEAF",
        "BATCH_ROOT_MISMATCH",
        "NULLIFIER_ALREADY_USED",
        "NULLIFIER_CROSS_CHAIN_REPLAY",
        "RELAY_TIMESTAMP_FUTURE",
        "RELAY_TIMESTAMP_MISSING",
        "INVALID_PROOF"
      ],
      "description": "Reason for expected failure, or null if expectedResult is pass"
    },
    "storageProof": {
      "type": "object",
      "description": "Optional storage proof data for storage-proof category vectors",
      "properties": {
        "blockHash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "accountAddress": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "storageSlot": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "storageValue": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+$"
        },
        "proofNodes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" }
        }
      },
      "required": ["blockHash", "accountAddress", "storageSlot", "storageValue", "proofNodes"]
    },
    "batchCheckpoint": {
      "type": "object",
      "description": "Optional batch checkpoint data for batch-checkpoint category vectors",
      "properties": {
        "batchRoot": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "leaf": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "leafIndex": {
          "type": "integer",
          "minimum": 0
        },
        "proof": {
          "type": "array",
          "items": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
        }
      },
      "required": ["batchRoot", "leaf", "leafIndex", "proof"]
    },
    "nullifier": {
      "type": "object",
      "description": "Optional nullifier data for nullifier-replay category vectors",
      "properties": {
        "nullifierHash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "scope": {
          "type": "string",
          "enum": ["global", "chain_scoped"]
        },
        "priorUsageChainId": {
          "type": ["integer", "null"]
        }
      },
      "required": ["nullifierHash", "scope"]
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata for documentation and tooling",
      "properties": {
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date" },
        "protocolVersion": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "expectedResult": { "const": "pass" } } },
      "then": { "properties": { "failureReason": { "const": null } } }
    },
    {
      "if": { "properties": { "expectedResult": { "const": "fail" } } },
      "then": { "properties": { "failureReason": { "not": { "const": null } } } }
    },
    {
      "if": { "properties": { "category": { "const": "storage_proof" } } },
      "then": { "required": ["storageProof"] }
    },
    {
      "if": { "properties": { "category": { "const": "batch_checkpoint" } } },
      "then": { "required": ["batchCheckpoint"] }
    },
    {
      "if": { "properties": { "category": { "const": "nullifier_replay" } } },
      "then": { "required": ["nullifier"] }
    }
  ],
  "additionalProperties": false
}
