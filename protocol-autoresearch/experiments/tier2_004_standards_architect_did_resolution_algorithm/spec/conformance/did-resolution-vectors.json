          ],
          "id": "did:bolyra:aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344",
          "controller": "did:bolyra:aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344",
          "verificationMethod": [
            {
              "id": "did:bolyra:aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344#human-auth-1",
              "type": "BolyraZkpAuthentication2024",
              "controller": "did:bolyra:aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344",
              "nullifierCommitment": "aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344",
              "proofPurpose": "authentication",
              "merkleTreeDepth": 20
            }
          ],
          "authentication": [
            "did:bolyra:aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344#human-auth-1"
          ],
          "assertionMethod": [],
          "service": [
            {
              "id": "did:bolyra:aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344#registry",
              "type": "BolyraRegistryService",
              "serviceEndpoint": {
                "registryAddress": "__REGISTRY_ADDRESS__",
                "chainId": "__CHAIN_ID__",
                "chainName": "__CHAIN_NAME__"
              }
            }
          ]
        },
        "didDocumentMetadata": {
          "created": "2024-07-01T16:00:00.000Z",
          "deactivated": false
        }
      }
    },
    {
      "id": "malformed",
      "description": "Attempt to resolve a malformed DID — expects invalidDid error",
      "input": {
        "did": "did:bolyra:NOT_VALID_HEX!!!"
      },
      "expected": {
        "didResolutionMetadata": {
          "error": "invalidDid"
        },
        "didDocument": null,
        "didDocumentMetadata": {}
      }
    },
    {
      "id": "deactivated",
      "description": "Resolve a revoked DID — expects deactivated error and metadata flag",
      "input": {
        "did": "did:bolyra:deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef"
      },
      "registry": {
        "commitment": "0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef",
        "keyType": 1,
        "publicKey": "0x0101010101010101010101010101010101010101010101010101010101010101020202020202020202020202020202020202020202020202020202020202020202",
        "merkleRoot": "0xcccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
        "timestamp": 1719849600,
        "active": false
      },
      "expected": {
        "didResolutionMetadata": {
          "error": "deactivated"
        },
        "didDocument": null,
        "didDocumentMetadata": {
          "deactivated": true
        }
      }
    }
  ]
