        "result": "FAIL",
        "reason": "scope_chain_mismatch",
        "revertError": "ScopeChainMismatch()"
      }
    },
    {
      "id": "phantom-delegatee-attack",
      "description": "Delegation to non-enrolled agent — delegateeMerkleRoot not in agentRootExists",
      "type": "delegation",
      "inputs": {
        "delegatorScope": "0xFF",
        "delegateeScope": "0x0F",
        "delegateeEnrolled": false
      },
      "expected": {
        "result": "FAIL",
        "reason": "stale_agent_root",
        "revertError": "StaleAgentRoot()",
        "note": "CIP-1: delegatee Merkle inclusion proof prevents phantom delegatees"
      }
    },
    {
      "id": "max-field-element-permission",
      "description": "Permission bitmask equals BN254 field modulus p — exceeds field, rejected before bit decomposition",
      "type": "enrollment",
      "inputs": {
        "permissionBitmask": "21888242871839275222246405745257275088548364400416034343698204186575808495617"
      },
      "expected": {
        "result": "FAIL",
        "reason": "field_overflow",
        "failsAt": "AgentPolicy circuit: bitmask >= p causes undefined behavior in Num2Bits",
        "note": "BN254 field modulus: values >= p are not valid field elements"
      }
    },
    {
