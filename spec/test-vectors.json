        "result": "FAIL",
        "reason": "scope_escalation_mid_chain",
        "failAtHop": 1
      }
    },
    {
      "id": "nonce-replay-attack",
      "description": "Second handshake with same nonce rejected by on-chain usedNonces mapping",
      "type": "handshake",
      "inputs": {
        "sessionNonce": "42",
        "isReplay": true
      },
      "expected": {
        "result": "FAIL",
        "reason": "nonce_already_used",
        "revertError": "NonceAlreadyUsed()"
      }
    },
    {
      "id": "nonce-reuse-different-agent",
      "description": "Same nonce used by different agent — still rejected (nonces are global, not per-agent)",
      "type": "handshake",
      "inputs": {
        "sessionNonce": "42",
        "isReplay": true,
        "differentAgent": true
      },
      "expected": {
        "result": "FAIL",
        "reason": "nonce_already_used",
        "revertError": "NonceAlreadyUsed()",
        "note": "Nonces are global to prevent cross-agent replay"
      }
    },
    {
      "id": "nonce-reuse-in-delegation",
      "description": "Delegation proof submitted with a nonce already consumed in a prior delegation",
      "type": "delegation",
      "inputs": {
        "delegatorScope": "0xFF",
        "delegateeScope": "0x0F",
        "sessionNonce": "42",
        "isNonceReplay": true
      },
      "expected": {
        "result": "FAIL",
        "reason": "nonce_already_used",
        "revertError": "NonceAlreadyUsed()"
      }
    },
    {
      "id": "delegation-without-handshake",
      "description": "Delegation attempted without prior handshake for this sessionNonce",
