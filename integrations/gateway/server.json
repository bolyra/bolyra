{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.bolyra/gateway",
  "description": "MCP auth gateway: verify agent identity, enforce per-tool permissions, block replays, emit receipts.",
  "repository": {
    "url": "https://github.com/bolyra/bolyra",
    "source": "github",
    "subfolder": "integrations/gateway"
  },
  "version": "0.3.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@bolyra/gateway",
      "version": "0.3.0",
      "transport": {
        "type": "stdio"
      },
      "arguments": [
        "--target",
        "http://localhost:3000/mcp"
      ],
      "environmentVariables": []
    }
  ]
}
