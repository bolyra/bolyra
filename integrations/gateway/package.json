{
  "name": "@bolyra/gateway",
  "version": "0.5.0",
  "mcpName": "io.github.bolyra/gateway",
  "description": "Bolyra MCP Auth Gateway — standalone reverse proxy that verifies agent ZKP credentials before forwarding to upstream MCP servers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "bolyra-gateway": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bolyra/mcp": "~0.6.0",
    "@bolyra/receipts": "~0.8.0",
    "@bolyra/sdk": ">=0.5.0",
    "@noble/hashes": "^1.7.0",
    "redis": "^4.7.1",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "@bolyra/sdk": ">=0.5.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bolyra/bolyra"
