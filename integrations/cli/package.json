{
  "name": "@bolyra/cli",
  "version": "0.1.1",
  "description": "CLI for Bolyra credential lifecycle management — create, inspect, revoke credentials; generate Ed25519 keys; verify receipts; generate dev identities.",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "bolyra": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bolyra/sdk": "^0.5.0",
    "@bolyra/receipts": "~0.7.0",
    "circomlibjs": "^0.1.7"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.0",
    "@types/jest": "^30.0.0"
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bolyra/bolyra"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bolyra",
    "cli",
    "credential",
    "zkp",
    "identity",
    "agent"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.11.0"
  }
