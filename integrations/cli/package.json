{
  "name": "@bolyra/cli",
  "version": "0.7.0",
  "description": "CLI for Bolyra credential lifecycle management \u2014 create, inspect, revoke credentials; generate Ed25519 keys; verify receipts; generate dev identities.",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "bolyra": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --passWithNoTests --forceExit",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "([ -f ../receipts/dist/index.d.ts ] || (cd ../receipts && npm install --silent --no-audit --no-fund && npm run build)) && ([ -f ../mpp-payments/dist/index.d.ts ] || (cd ../mpp-payments && npm install --silent --no-audit --no-fund && npm run build))"
  },
  "dependencies": {
    "@bolyra/sdk": "^0.6.0",
    "@bolyra/mcp": "^0.6.4",
    "@bolyra/mpp": "^0.2.0",
    "@bolyra/receipts": "~0.9.0",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.0",
    "@types/jest": "^30.0.0"
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bolyra/bolyra"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bolyra",
    "cli",
    "credential",
    "zkp",
    "identity",
    "agent"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.11.0"
  },
  "overrides": {
    "ws": "8.21.0",
    "underscore": "1.13.8"
  }
}
